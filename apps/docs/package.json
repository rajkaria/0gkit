{
  "name": "@foundryprotocol/0gkit-docs",
  "version": "0.0.0",
  "private": true,
  "description": "0gkit documentation — the complete guide to the neutral 0G builder toolkit.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/gen-llms.mjs",
    "gen:llms": "node scripts/gen-llms.mjs",
    "build": "node scripts/gen-llms.mjs && next build --webpack && pnpm pagefind:build",
    "pagefind:build": "pagefind --site .next/server/app --output-path public/pagefind || pagefind --site .next --output-path public/pagefind",
    "start": "next start",
    "clean": "rimraf .next .turbo public/pagefind public/llms public/llms.txt public/llms-full.txt",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx-frontmatter": "^5.0.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "pagefind": "^1.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
