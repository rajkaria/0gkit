# --- server (Node only) ---
# 0G galileo JSON-RPC endpoint (read-only network status)
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# signer key — optional; enables 0G Storage pins + live-feed posts
OG_PRIVATE_KEY=

# 0G Router key (pc.0g.ai) — optional; enables the AI summary via Compute.router()
ROUTER_API_KEY=

# deployed FeedEvents address — optional; enables reorg-safe live-feed
OG_FEED_CONTRACT_ADDRESS=

# --- client (browser-safe, NEXT_PUBLIC_*) ---
# network label shown in the UI
NEXT_PUBLIC_OG_NETWORK=galileo
