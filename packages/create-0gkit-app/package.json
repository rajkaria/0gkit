{
  "name": "create-0gkit-app",
  "version": "1.0.4",
  "description": "Scaffold a 0G app in seconds. `npm create 0gkit-app@latest`.",
  "type": "module",
  "bin": {
    "create-0gkit-app": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^14.0.0",
    "execa": "^9.0.0",
    "giget": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.10"
  },
  "license": "MIT",
  "homepage": "https://0gkit.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajkaria/0gkit.git",
    "directory": "packages/create-0gkit-app"
  },
  "bugs": {
    "url": "https://github.com/rajkaria/0gkit/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
