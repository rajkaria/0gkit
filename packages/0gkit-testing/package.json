{
  "name": "@foundryprotocol/0gkit-testing",
  "version": "0.3.0",
  "description": "Test toolkit for 0gkit: deterministic mock providers for storage/compute/DA, signed fixture attestations + receipts, an HD-derived testWallet, a setupLocalDevnet() vitest helper that wraps `0g dev`, and four vitest matchers (toBeConfirmedOn0G, toHaveRootMatching, toBeValidAttestation, toBeZeroGError).",
  "license": "MIT",
  "homepage": "https://github.com/rajkaria/0gkit/tree/main/packages/0gkit-testing",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajkaria/0gkit.git",
    "directory": "packages/0gkit-testing"
  },
  "bugs": {
    "url": "https://github.com/rajkaria/0gkit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./matchers": {
      "types": "./dist/matchers.d.ts",
      "import": "./dist/matchers.js"
    },
    "./mocks": {
      "types": "./dist/mocks.d.ts",
      "import": "./dist/mocks.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "import": "./dist/fixtures.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "depcruise src --config ../../.dependency-cruiser.cjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@foundryprotocol/0gkit-core": "workspace:*",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "viem": "^2.21.0",
    "vitest": "^2.1.8"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@foundryprotocol/0gkit-devnet": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "dependency-cruiser": "^16.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "0g",
    "0g-network",
    "testing",
    "vitest",
    "mocks",
    "fixtures",
    "toolkit"
  ],
  "publishConfig": {
    "access": "public"
  }
}
