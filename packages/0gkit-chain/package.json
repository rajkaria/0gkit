{
  "name": "@foundryprotocol/0gkit-chain",
  "version": "0.2.0",
  "description": "Neutral 0G chain helpers — explorer URLs, balance, waitForReceipt, testnet faucet. Built on @foundryprotocol/0gkit-core + viem.",
  "license": "MIT",
  "homepage": "https://github.com/rajkaria/0gkit/tree/main/packages/0gkit-chain",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajkaria/0gkit.git",
    "directory": "packages/0gkit-chain"
  },
  "bugs": {
    "url": "https://github.com/rajkaria/0gkit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "depcruise src --config ../../.dependency-cruiser.cjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@foundryprotocol/0gkit-core": "workspace:*",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@foundryprotocol/0gkit-wallet": "workspace:*",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "0g",
    "0g-network",
    "viem",
    "faucet",
    "explorer",
    "toolkit"
  ],
  "publishConfig": {
    "access": "public"
  }
}
