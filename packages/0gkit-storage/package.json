{
  "name": "@foundryprotocol/0gkit-storage",
  "version": "0.4.0",
  "description": "Neutral 0G Storage client — upload/download/computeRoot/exists over @0gfoundation/0g-storage-ts-sdk.",
  "license": "MIT",
  "homepage": "https://github.com/rajkaria/0gkit/tree/main/packages/0gkit-storage",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajkaria/0gkit.git",
    "directory": "packages/0gkit-storage"
  },
  "bugs": {
    "url": "https://github.com/rajkaria/0gkit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "depcruise src --config ../../.dependency-cruiser.cjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@foundryprotocol/0gkit-core": "workspace:*",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "viem": "^2.21.0",
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.9",
    "ethers": "6.13.1"
  },
  "peerDependenciesMeta": {
    "@0gfoundation/0g-storage-ts-sdk": {
      "optional": true
    },
    "ethers": {
      "optional": true
    },
    "@foundryprotocol/0gkit-testing": {
      "optional": true
    }
  },
  "devDependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.9",
    "@foundryprotocol/0gkit-testing": "workspace:*",
    "@foundryprotocol/0gkit-wallet": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "dependency-cruiser": "^16.0.0",
    "ethers": "6.13.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "0g",
    "0g-storage",
    "storage",
    "toolkit"
  ],
  "publishConfig": {
    "access": "public"
  }
}
