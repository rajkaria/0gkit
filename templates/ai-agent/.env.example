# --- server (Node only) ---
# 0G network for compute calls.
ZEROG_NETWORK=galileo

# Funded broker key for 0G Compute client-side routing (testnet OK).
BROKER_KEY=

# 0G Router API key (pc.0g.ai); set to use the managed Router endpoint.
ROUTER_API_KEY=

# Optional pinned compute provider address; router picks one if blank.
PROVIDER=

# Optional pinned model name; defaults to provider's default.
MODEL=
