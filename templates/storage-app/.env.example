# A funded private key that pays the 0G Storage upload transaction.
# 64-char hex, with or without the 0x prefix. Generate one with `cast wallet new`.
PRIVATE_KEY=

# Which 0G network to use: "galileo" (testnet, default) or "aristotle" (mainnet).
# Get free testnet funds at https://faucet.0g.ai
ZEROG_NETWORK=galileo
