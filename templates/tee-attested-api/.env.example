# --- server (Node only) ---
# 0G network for compute calls.
ZEROG_NETWORK=galileo

# Signs attested API responses + funds client-side compute routing.
PRIVATE_KEY=

# 0G Router API key (pc.0g.ai); set to use the managed Router endpoint.
ROUTER_API_KEY=

# Model to route to (required when ROUTER_API_KEY is set).
MODEL=

# HTTP port for the Hono server.
PORT=8787
