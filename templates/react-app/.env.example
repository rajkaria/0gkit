# --- client (browser-safe, NEXT_PUBLIC_*) ---
# NOTE: anything NEXT_PUBLIC_* is shipped to the browser. A real upload key
# must never be a public env var — for production, proxy uploads through a
# server route / the 0gkit CLI. These are here so the demo form is wired
# end-to-end; the attestation panel needs no key at all.

# Which 0G network the upload form targets.
NEXT_PUBLIC_ZEROG_NETWORK=galileo

# Demo-only upload key — blank disables the upload form.
NEXT_PUBLIC_DEMO_PRIVATE_KEY=
