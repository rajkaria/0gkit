# Environment passed through to the 0gkit MCP server. All optional — the
# server defaults to the Galileo testnet and only needs keys for the tools
# you actually call.

# Network preset: "galileo" (testnet, default), "aristotle" (mainnet), "local".
ZEROG_NETWORK=galileo

# Override the preset EVM JSON-RPC URL (optional).
ZEROG_RPC_URL=

# Signer key — funds 0G Storage uploads (og_storage_put).
ZEROG_PRIVATE_KEY=

# Funded broker key for inference (og_infer).
ZEROG_BROKER_KEY=

# Default 0G inference provider address (og_infer).
ZEROG_PROVIDER=

# Set to 1 to enable the opt-in Foundry plugin (off by default).
ZEROG_FOUNDRY=
