# --- server (Node only) ---
# Environment passed through to the 0gkit MCP server. All optional — the
# server defaults to the Galileo testnet and only needs keys for the tools
# you actually call.

# Network preset: "galileo", "aristotle", or "local".
ZEROG_NETWORK=galileo

# Override the preset EVM JSON-RPC URL.
ZEROG_RPC_URL=

# Signer for og_storage_put.
ZEROG_PRIVATE_KEY=

# Broker for og_infer.
ZEROG_BROKER_KEY=

# Pinned compute provider address for og_infer.
ZEROG_PROVIDER=

# Enable opt-in Foundry plugin (1 = on, 0 = off).
ZEROG_FOUNDRY=0
