# --- server (Node only) ---

# 0G network for inference.
ZEROG_NETWORK=galileo

# Funded 0G broker key for client-side routing (used when ROUTER_API_KEY is blank).
BROKER_KEY=

# 0G Router API key (pc.0g.ai); set to use the managed Router endpoint.
ROUTER_API_KEY=

# Pin a provider address; blank = router picks one.
PROVIDER=

# Pin a model name; blank = provider default.
MODEL=

# Prompt to send.
PROMPT=In one sentence, what is the 0G network?
