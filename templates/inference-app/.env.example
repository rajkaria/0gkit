# A funded 0G broker private key that pays for inference.
# 64-char hex, with or without the 0x prefix.
BROKER_KEY=

# The on-chain 0G inference provider address to query.
# Leave blank to discover one automatically from the provider list.
PROVIDER=

# Which 0G network to use: "galileo" (testnet, default) or "aristotle" (mainnet).
ZEROG_NETWORK=galileo

# Optional: pin a model name. If unset, the provider's default model is used.
MODEL=

# The prompt to send.
PROMPT=In one sentence, what is the 0G network?
